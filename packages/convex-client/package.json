{
	"name": "@hubble.md/convex-client",
	"version": "0.0.1",
	"description": "Convex client for the Tubble.md sync engine",
	"license": "MIT",
	"author": "Ben Holmes <hey@bholmes.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/adrianricardo/tubble.md.git",
		"directory": "packages/convex-client"
	},
	"homepage": "https://tubble.nopalstudio.com",
	"bugs": "https://github.com/adrianricardo/tubble.md/issues",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"upstream:audit": "pnpm -w upstream:audit",
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
		"test": "vitest run"
	},
	"dependencies": {
		"@hubble.md/sync": "workspace:*",
		"@hubble.md/sync-backend": "workspace:*",
		"convex": "^1.34.0"
	},
	"devDependencies": {
		"typescript": "~5.8.3",
		"vitest": "^3.2.4"
	}
}
