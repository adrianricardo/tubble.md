{
	"name": "@hubble.md/cloud-ui",
	"version": "0.0.1",
	"private": true,
	"description": "Shared Convex-aware cloud UI for Hubble.md",
	"license": "MIT",
	"author": "Ben Holmes <hey@bholmes.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bholmesdev/hubble.md.git",
		"directory": "packages/cloud-ui"
	},
	"homepage": "https://hubble.md",
	"bugs": "https://github.com/bholmesdev/hubble.md/issues",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "vite build && tsc -p tsconfig.json --emitDeclarationOnly",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "vite build --watch",
		"test": "vitest run"
	},
	"dependencies": {
		"@base-ui/react": "^1.3.0",
		"@hubble.md/sync-backend": "workspace:*",
		"@hubble.md/ui": "workspace:*"
	},
	"peerDependencies": {
		"convex": "^1.34.0",
		"react": "^19.1.0",
		"react-dom": "^19.1.0"
	},
	"devDependencies": {
		"@iconify-json/mingcute": "^1.2.7",
		"@types/react": "^19.1.8",
		"typescript": "~5.8.3",
		"unplugin-icons": "^23.0.1",
		"vite": "^7.0.4",
		"vitest": "^3.2.4"
	}
}
