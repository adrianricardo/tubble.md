{
	"name": "@hubble.md/sync",
	"version": "0.0.1",
	"description": "Filesystem sync engine for Tubble.md",
	"license": "MIT",
	"author": "Ben Holmes <hey@bholmes.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/adrianricardo/tubble.md.git",
		"directory": "packages/sync"
	},
	"homepage": "https://github.com/adrianricardo/tubble.md",
	"bugs": "https://github.com/adrianricardo/tubble.md/issues",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/fs-node.d.ts",
			"default": "./dist/fs-node.js"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"upstream:audit": "pnpm -w upstream:audit",
		"build": "tsc -p tsconfig.json",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
		"test": "vitest run"
	},
	"dependencies": {
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"typescript": "~5.8.3",
		"vitest": "^3.2.4"
	}
}
