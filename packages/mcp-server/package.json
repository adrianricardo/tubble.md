{
	"name": "@hubble.md/mcp-server",
	"version": "0.0.1",
	"description": "MCP server for Hubble.md Live Document agent editing",
	"license": "MIT",
	"author": "Ben Holmes <hey@bholmes.dev>",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/bholmesdev/hubble.md.git",
		"directory": "packages/mcp-server"
	},
	"homepage": "https://hubble.md",
	"bugs": {
		"url": "https://github.com/bholmesdev/hubble.md/issues"
	},
	"type": "module",
	"bin": {
		"hubble-mcp": "./dist/index.js"
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsc -p tsconfig.json",
		"postbuild": "chmod +x dist/index.js",
		"typecheck": "tsc -p tsconfig.json --noEmit",
		"dev": "tsc -p tsconfig.json --watch --preserveWatchOutput"
	},
	"dependencies": {
		"@hubble.md/convex-client": "workspace:*",
		"@hubble.md/sync": "workspace:*",
		"@modelcontextprotocol/sdk": "^1.29.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"typescript": "~5.8.3"
	}
}
