# Agent test bootstrap. Copy to .env.local and fill in.
# When set, navigating to http://localhost:5173/?test=1 skips the
# connect + workspace screens and loads the workspace directly.
# Add &testUser=Ada or use the in-app prompt to identify one browser;
# use a different value in a second browser for the realtime POC.
# Without ?test=1 these are inert — normal dev sessions are unaffected.
VITE_TEST_CONVEX_URL=
VITE_TEST_WORKSPACE_ID=
