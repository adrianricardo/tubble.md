{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "default",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:default",
		"dialog:default",
		"dialog:allow-save",
		"fs:allow-watch",
		"fs:allow-unwatch",
		{
			"identifier": "fs:scope",
			"allow": [{ "path": "$HOME/**" }]
		},
		"opener:default"
	]
}
